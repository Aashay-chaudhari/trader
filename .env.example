# Copy this to .env and fill in your keys.
# NEVER commit .env to git.

# LLM API Keys (at least one required)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Alpaca Paper Trading (free at alpaca.markets)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# LLM Models
# Sonnet for morning research (deep, about $0.02/call)
# Haiku for monitoring checks (cheap, about $0.001/call)
LLM_PROVIDER=auto
RESEARCH_MODEL=claude-sonnet-4-6
MONITOR_MODEL=claude-haiku-4-5-20251001
RESEARCH_MODEL_OPENAI=gpt-4o-mini

# News and Data APIs (all free tier)
# Marketaux: entity-linked news, 100 req/day free
MARKETAUX_API_KEY=

# FRED: macro regime data (VIX, yields, spreads)
FRED_API_KEY=

# SEC EDGAR: no key needed, but requires user-agent declaration
# Format: "YourName your-email@example.com"
SEC_EDGAR_USER_AGENT=

# Finnhub: company news, social sentiment, insider trades, analyst trends
# 60 calls/min free
FINNHUB_API_KEY=

# Alpha Vantage: NLP-scored news with per-ticker sentiment relevance
# 25 calls/day free
ALPHA_VANTAGE_API_KEY=

# CLI Agent Mode
# When true, use a repo-aware CLI agent first and fall back to direct API calls.
USE_CLI_AGENT=false
CLI_AGENT_PROVIDER=claude
CLI_AGENT_MAX_TURNS=5
CLI_AGENT_TIMEOUT=300

# Strategist Profile Isolation
# Point each strategist run at its own artifact root when comparing books.
DATA_DIR=data
AGENT_PROFILE=default
AGENT_LABEL=

# Debug Mode
# When true: fewer stocks (3), cheaper model (Haiku), skip web research.
# Use for testing architecture without burning API credits.
DEBUG_MODE=false
DEBUG_MAX_STOCKS=3
DEBUG_SKIP_WEB=true

# Knowledge Accumulation
# Controls how much accumulated knowledge is loaded into research prompts.
ENABLE_KNOWLEDGE_BASE=true
KNOWLEDGE_TOKEN_BUDGET=1500
OBSERVATIONS_TOKEN_BUDGET=500
OBSERVATION_RETENTION_DAYS=90

# Swing Trading
# Track multi-day positions with daily updates and stop/target monitoring.
ENABLE_SWING_TRACKING=true

# Trading Config
DRY_RUN=true
PAPER_PORTFOLIO_VALUE=100000

# Risk Limits
MAX_POSITION_PCT=10.0
MAX_DAILY_LOSS_PCT=2.0
MIN_SIGNAL_STRENGTH=0.3
MIN_STRATEGIES_AGREE=2
GUARANTEE_DAILY_TRADE=true
