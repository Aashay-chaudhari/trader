# Copy this to .env and fill in your keys
# NEVER commit .env to git

# ── LLM API Keys (at least one required) ──
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Alpaca Paper Trading (free at alpaca.markets) ──
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# ── LLM Models ──
# Sonnet for morning research (deep, ~$0.02/call)
# Haiku for monitoring checks (cheap, ~$0.001/call)
RESEARCH_MODEL=claude-sonnet-4-6
MONITOR_MODEL=claude-haiku-4-5-20251001
RESEARCH_MODEL_OPENAI=gpt-4o-mini

# ── Trading Config ──
DRY_RUN=true
PAPER_PORTFOLIO_VALUE=100000

# ── Risk Limits ──
MAX_POSITION_PCT=10.0
MAX_DAILY_LOSS_PCT=2.0
MIN_SIGNAL_STRENGTH=0.3
MIN_STRATEGIES_AGREE=2
GUARANTEE_DAILY_TRADE=true
