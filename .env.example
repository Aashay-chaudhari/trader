# Copy this to .env and fill in your keys.
# NEVER commit .env to git.

# LLM API Keys (at least one required)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Alpaca Paper Trading (free at alpaca.markets — no subscription needed)
# For dual-strategist setup: create 2 paper accounts (different emails).
# GitHub CI uses ALPACA_API_KEY_CLAUDE / ALPACA_API_KEY_CODEX for isolation.
# For local single-strategist runs, just set ALPACA_API_KEY + ALPACA_SECRET_KEY.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
# Per-strategist keys (set these as GitHub Secrets for separate paper books):
# ALPACA_API_KEY_CLAUDE=
# ALPACA_SECRET_KEY_CLAUDE=
# ALPACA_API_KEY_CODEX=
# ALPACA_SECRET_KEY_CODEX=

# LLM Models
# Sonnet for morning research (deep, about $0.02/call)
# Haiku for monitoring checks (cheap, about $0.001/call)
LLM_PROVIDER=auto
RESEARCH_MODEL=claude-sonnet-4-6
MONITOR_MODEL=claude-haiku-4-5-20251001
RESEARCH_MODEL_OPENAI=gpt-4o-mini
MONITOR_MODEL_OPENAI=gpt-4o-mini
LLM_MAX_OUTPUT_TOKENS=4000
LLM_MAX_PROMPT_CHARS=80000

# News and Data APIs (all free tier)
# Marketaux: entity-linked news, 100 req/day free
MARKETAUX_API_KEY=

# FRED: macro regime data (VIX, yields, spreads)
FRED_API_KEY=

# SEC EDGAR: no key needed, but requires user-agent declaration
# Format: "YourName your-email@example.com"
SEC_EDGAR_USER_AGENT=

# Finnhub: company news, social sentiment, insider trades, analyst trends
# 60 calls/min free
FINNHUB_API_KEY=

# Alpha Vantage: NLP-scored news with per-ticker sentiment relevance
# 25 calls/day free
ALPHA_VANTAGE_API_KEY=

# CLI Agent Mode
# Local-only option: use a repo-aware CLI agent first and fall back to direct API calls.
# GitHub Actions monitor runs API-only by default.
USE_CLI_AGENT=false
USE_CLI_AGENT_FOR_MONITOR=false
CLI_AGENT_PROVIDER=claude
CLI_AGENT_MAX_TURNS=5
CLI_AGENT_TIMEOUT=300

# Strategist Profile Isolation
# Point each strategist run at its own artifact root when comparing books.
DATA_DIR=data
AGENT_PROFILE=default
AGENT_LABEL=

# Run Mode — single control variable for the entire system
#   "debug"  — template responses, no LLM calls, no orders, 3 stocks (default)
#   "paper"  — real LLM calls, Alpaca paper orders, full pipeline
#   "live"   — real LLM calls, Alpaca live orders (future)
RUN_MODE=debug
# Legacy vars (still supported for backward compat): DEBUG_MODE, DRY_RUN, PRODUCTION_MODE

# Knowledge Accumulation
# Controls how much accumulated knowledge is loaded into research prompts.
ENABLE_KNOWLEDGE_BASE=true
KNOWLEDGE_TOKEN_BUDGET=1500
OBSERVATIONS_TOKEN_BUDGET=500
OBSERVATION_RETENTION_DAYS=90

# Swing Trading
# Track multi-day positions with daily updates and stop/target monitoring.
ENABLE_SWING_TRACKING=true

# Trading Config
# RUN_MODE controls execution semantics:
#   debug -> no orders
#   paper -> Alpaca paper orders
#   live  -> real orders (future path)
PAPER_PORTFOLIO_VALUE=100000
# Default watchlist (comma-separated). Overridden by screener output in production.
# WATCHLIST=AAPL,MSFT,NVDA,GOOGL,AMZN,META,TSLA,AMD,CRM,NFLX

# Risk Limits
MAX_POSITION_PCT=10.0
MAX_DAILY_LOSS_PCT=2.0
MIN_SIGNAL_STRENGTH=0.3
MIN_STRATEGIES_AGREE=2
GUARANTEE_DAILY_TRADE=true
MONITOR_CANDIDATE_LIMIT=3
MONITOR_ENTRY_PROXIMITY_PCT=2.0

# Push Notifications — ntfy.sh (FREE, no signup, no account)
# 1. Install the ntfy app on your phone (iOS App Store / Google Play)
# 2. Pick a unique topic name (e.g., "agent-trader-yourname")
# 3. Subscribe to that topic in the app
# 4. Set NTFY_TOPIC below — that's it, you'll get push notifications
NTFY_TOPIC=                          # e.g., "agent-trader-yourname"
NTFY_SERVER=https://ntfy.sh          # Public server (or self-host)

# Optional: Twilio SMS fallback (paid, requires signup at twilio.com)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+1XXXXXXXXXX
# ALERT_PHONE_NUMBER=+1XXXXXXXXXX

# Alert toggles
ENABLE_TRADE_ALERTS=true             # Notify when trades execute
ENABLE_DAILY_SUMMARY=true            # End-of-day P&L notification
ENABLE_ERROR_ALERTS=true             # Notify on pipeline errors
