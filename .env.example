# Copy this file to .env and fill in your own keys.
# Never commit .env to git.

# LLM API Keys (used by the Python monitor runtime)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Alpaca Paper Trading
# Local CLI research does not use these.
# GitHub Actions monitor uses per-strategist paper keys from repository secrets.
# Local Python monitor runs use ALPACA_API_KEY and ALPACA_SECRET_KEY from .env.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# LLM Models
# Heavy morning and reflection work is intended to run locally through CLI subscriptions.
# The Python runtime uses the monitor models for cheap intraday approval checks.
LLM_PROVIDER=auto
MONITOR_LLM_PROVIDER=openai
RESEARCH_MODEL=claude-sonnet-4-6
MONITOR_MODEL=claude-haiku-4-5-20251001
RESEARCH_MODEL_OPENAI=gpt-4o-mini
MONITOR_MODEL_OPENAI=gpt-4o-mini
LLM_MAX_OUTPUT_TOKENS=4000
LLM_MAX_PROMPT_CHARS=80000

# News and Data APIs
MARKETAUX_API_KEY=
FRED_API_KEY=
SEC_EDGAR_USER_AGENT=
FINNHUB_API_KEY=
ALPHA_VANTAGE_API_KEY=

# Default Python runtime profile
# Local `run_both.sh` manages the claude and codex profiles directly.
DATA_DIR=data/profiles/default
AGENT_PROFILE=default
AGENT_LABEL=

# Single control variable for the Python runtime
# debug - template responses, no orders
# paper - real LLM calls, Alpaca paper orders
# live  - future live-trading path
RUN_MODE=debug

# Knowledge and memory
ENABLE_KNOWLEDGE_BASE=true
KNOWLEDGE_TOKEN_BUDGET=1500
OBSERVATIONS_TOKEN_BUDGET=500
OBSERVATION_RETENTION_DAYS=90
ENABLE_SWING_TRACKING=true

# Trading config
PAPER_PORTFOLIO_VALUE=100000
MAX_POSITION_PCT=10.0
MAX_DAILY_LOSS_PCT=2.0
MIN_SIGNAL_STRENGTH=0.3
MIN_STRATEGIES_AGREE=2
GUARANTEE_DAILY_TRADE=true
MONITOR_CANDIDATE_LIMIT=3
MONITOR_ENTRY_PROXIMITY_PCT=2.0

# Notifications
NTFY_TOPIC=
NTFY_SERVER=https://ntfy.sh
ENABLE_TRADE_ALERTS=true
ENABLE_DAILY_SUMMARY=true
ENABLE_ERROR_ALERTS=true
